# local-stub | generic-json
PROTEIN_MODEL_PROVIDER=local-stub
PROTEIN_MODEL_NAME=saprot-protein-predictor
PROTEIN_MODEL_BASE_URL=
PROTEIN_MODEL_API_KEY=
PROTEIN_MODEL_TIMEOUT_SECONDS=30

PEPTIDE_MODEL_PROVIDER=local-stub
PEPTIDE_MODEL_NAME=paired-peptide-generator
PEPTIDE_MODEL_BASE_URL=
PEPTIDE_MODEL_API_KEY=
PEPTIDE_MODEL_TIMEOUT_SECONDS=30

APTAMER_MODEL_PROVIDER=local-stub
APTAMER_MODEL_NAME=nucleic-aptamer-generator
APTAMER_MODEL_BASE_URL=
APTAMER_MODEL_API_KEY=
APTAMER_MODEL_TIMEOUT_SECONDS=30

# Optional Router LLM for natural-language task classification.
# If ROUTER_LLM_* is empty, the app will fallback to LLM_* variables.
ROUTER_LLM_PROVIDER=
ROUTER_LLM_MODEL_NAME=
ROUTER_LLM_BASE_URL=
ROUTER_LLM_API_KEY=
ROUTER_LLM_TIMEOUT_SECONDS=30
ROUTER_LLM_FALLBACK_TO_KEYWORDS=true

# Generic shared LLM aliases. Can be used directly by the Router LLM config.
LLM_PROVIDER=
MODEL_NAME=
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_TIMEOUT_SECONDS=30

MIN_PROTEIN_SEQUENCE_LENGTH=8

RAG_ENABLED=true
RAG_BACKEND=local-hash
RAG_TOP_K=3
RAG_DATA_PATH=
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

DATABASE_URL=sqlite+aiosqlite:///./protein_agent.db
CELERY_BROKER_URL=redis://localhost:6379/0
